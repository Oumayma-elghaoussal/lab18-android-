<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- SECTION 1 — Mode Avion (Receiver dynamique) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:orientation="vertical" android:padding="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/section_airplane" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvAirplaneStatus"
                    android:text="@string/airplane_status"
                    android:textSize="15sp" android:textColor="#333"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:text="ℹ️ Enregistré dynamiquement dans onCreate().\nActivez/désactivez le mode avion pour tester."
                    android:textSize="12sp" android:textColor="#888"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SECTION 2 — BOOT_COMPLETED (Receiver statique) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:orientation="vertical" android:padding="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/section_boot" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <TextView android:text="@string/boot_info"
                    android:textSize="13sp" android:textColor="#555"
                    android:lineSpacingExtra="4dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SECTION 3 — Broadcast custom -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:orientation="vertical" android:padding="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/section_custom" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etMessage"
                    android:hint="@string/hint_message"
                    android:inputType="text"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnSendBroadcast"
                    android:text="@string/btn_send_broadcast"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvCustomResult"
                    android:text="@string/custom_result"
                    android:textSize="14sp" android:textColor="#333"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- SECTION 4 — Journal des événements -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">
            <LinearLayout android:orientation="vertical" android:padding="16dp"
                android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="@string/section_log" android:textSize="16sp"
                    android:textStyle="bold" android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <TextView android:id="@+id/tvLog"
                    android:text="" android:textSize="12sp" android:textColor="#444"
                    android:fontFamily="monospace" android:lineSpacingExtra="3dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>
                <Button android:id="@+id/btnClearLog"
                    android:text="@string/btn_clear_log"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
